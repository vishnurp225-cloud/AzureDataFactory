{
	"name": "dataflow4Derived",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DelimitedText14",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          emp_id as string,",
				"          name as string,",
				"          salary as string,",
				"          address as string,",
				"          loc as string,",
				"          email as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(name = iif(isNull(name),\"Unknown\",name),",
				"          salary = iif(isNull(salary),'100000',salary),",
				"          Country = upper(address)) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          ID = emp_id,",
				"          NAME = name,",
				"          SALARY = salary,",
				"          ADDRESS = address,",
				"          COUNTRY = Country",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1"
			]
		}
	}
}