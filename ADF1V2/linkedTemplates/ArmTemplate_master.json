{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "ADF1V2"
		},
		"sa1vp1ls1_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'sa1vp1ls1'"
		},
		"AzureSqlDatabase1_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sql1vpserver.database.windows.net"
		},
		"AzureSqlDatabase1_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "@{linkedService().DatabaseName}"
		},
		"AzureSqlDatabase1_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "gautham"
		},
		"LS_Keyvault_Dev_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://KV-Dev-VP.vault.azure.net/"
		},
		"Pipeline2-Trigger_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/7e903a24-a469-4dc8-a4ad-d97e5be88b1f/resourceGroups/RG1/providers/Microsoft.Storage/storageAccounts/sa1vp1"
		},
		"TumblingTrigger1_properties_pipeline_parameters_pstartdate": {
			"type": "string",
			"defaultValue": "@trigger().outputs.windowstarttime"
		},
		"TumblingTrigger1_properties_pipeline_parameters_penddate": {
			"type": "string",
			"defaultValue": "@trigger().outputs.windowEndtime"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "ADF1V2_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"sa1vp1ls1_connectionString": {
						"value": "[parameters('sa1vp1ls1_connectionString')]"
					},
					"LS_Keyvault_Dev_properties_typeProperties_baseUrl": {
						"value": "[parameters('LS_Keyvault_Dev_properties_typeProperties_baseUrl')]"
					},
					"AzureSqlDatabase1_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDatabase1_properties_typeProperties_server')]"
					},
					"AzureSqlDatabase1_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDatabase1_properties_typeProperties_database')]"
					},
					"AzureSqlDatabase1_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDatabase1_properties_typeProperties_userName')]"
					},
					"Pipeline2-Trigger_properties_typeProperties_scope": {
						"value": "[parameters('Pipeline2-Trigger_properties_typeProperties_scope')]"
					},
					"TumblingTrigger1_properties_pipeline_parameters_pstartdate": {
						"value": "[parameters('TumblingTrigger1_properties_pipeline_parameters_pstartdate')]"
					},
					"TumblingTrigger1_properties_pipeline_parameters_penddate": {
						"value": "[parameters('TumblingTrigger1_properties_pipeline_parameters_penddate')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}